# Stone Indexer Production Configuration
#
# Copy this file to .env and fill in the values:
#   cp env.example .env
#
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# Domain for HTTPS (e.g., indexer.stone.finance)
DOMAIN=indexer.example.com

# PostgreSQL credentials - USE STRONG PASSWORDS!
# Generate with: openssl rand -base64 32
POSTGRES_USER=stone
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=stone

# Blockchain RPC endpoint
RPC_ENDPOINT=https://rpc.neutron.network

# Chain ID (e.g., neutron-1, pion-1)
CHAIN_ID=neutron-1

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Starting block height (default: 1)
# START_BLOCK_HEIGHT=1

# Polling interval in milliseconds (default: 1000)
# POLL_INTERVAL_MS=1000

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Custom indexer image (default: ghcr.io/stonefinance/stone-indexer:latest)
# INDEXER_IMAGE=ghcr.io/stonefinance/stone-indexer:v1.0.0
